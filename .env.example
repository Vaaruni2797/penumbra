# ─────────────────────────────────────────────
# 🌒 Penumbra — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Never commit .env to GitHub.
# ─────────────────────────────────────────────

# Mistral API — get yours at https://console.mistral.ai
MISTRAL_API_KEY=

# HuggingFace — get yours at https://huggingface.co/settings/tokens
# Needs write access to upload model weights
HF_TOKEN=
HF_USERNAME=your_hf_username_here
HF_REPO_ID=your_hf_username_here/penumbra-ministral-3b

# Weights & Biases — get yours at https://wandb.ai/settings
# Used for tracking training runs and calibration metrics
WANDB_API_KEY=
WANDB_PROJECT=penumbra
WANDB_RUN_URL=https://wandb.ai
